# Dependencies — reinstalled inside the image
node_modules/

# Build output — created inside the image
dist/

# .env is included so generate-env-ts.mjs can read it at build time.
# .env.* variants (e.g. .env.production, .env.local) are still excluded.
.env.*

# Dev / test artifacts
e2e/
coverage/
.angular/

# Git & IDE
.git/
.gitignore
.vscode/
.idea/

# Docs & references (not needed at runtime)
docs/
pelis-plus-references/
*.md
!README.md

# OS noise
.DS_Store
Thumbs.db
