# Angular app environment (must use NG_APP_ prefix for Angular)
# -------------------------------------------------------------------
# INDEX PAGE SWITCH:
# NG_APP_INDEX_PAGE supports ONLY:
# - landing
# - login
#
# QUICK START:
# 1) Copy this file to .env
# 2) Use ONE of the blocks below (development or production)

# =========================
# Development example
# =========================
NG_APP_PRODUCTION=false
NG_APP_NAME="UTP Angular Boilerplate (Dev)"
NG_APP_INDEX_PAGE="login"
NG_APP_POST_LOGIN_ROUTE="/landing"
NG_APP_BACKEND_BASE_URL="http://localhost:8080/api"
NG_APP_AUTH_DEMO_EMAIL="admin@example.com"
NG_APP_AUTH_DEMO_PASSWORD="Password123!"
NG_APP_AUTH_TOKEN_STORAGE_KEY="utp_auth_token_dev"

# =========================
# Production example
# =========================
# NG_APP_PRODUCTION=true
# NG_APP_NAME="UTP Angular Boilerplate"
# NG_APP_INDEX_PAGE="landing"
# NG_APP_POST_LOGIN_ROUTE="/landing"
# NG_APP_BACKEND_BASE_URL="https://api.example.com"
# NG_APP_AUTH_DEMO_EMAIL="admin@example.com"
# NG_APP_AUTH_DEMO_PASSWORD="Password123!"
# NG_APP_AUTH_TOKEN_STORAGE_KEY="utp_auth_token"

# Server (SSR)
# Port used by src/server.ts when running the Node server.
PORT=4000

# Playwright
# Base URL used by Playwright tests (playwright.config.ts).
PLAYWRIGHT_TEST_BASE_URL=http://localhost:4200

# CI flag (optional)
# Set to true in CI environments to enable retries/worker constraints.
CI=false
