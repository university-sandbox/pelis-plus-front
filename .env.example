# Angular app environment (must use NG_APP_ prefix for Angular)
# -------------------------------------------------------------------
# QUICK START:
# 1) Copy this file to .env
# 2) Fill in the values for your environment
#
# INDEX PAGE options: catalog | landing | login

# =========================
# Development example
# =========================
NG_APP_PRODUCTION=false
NG_APP_NAME="Pelis Plus"
NG_APP_INDEX_PAGE=catalog
NG_APP_POST_LOGIN_ROUTE=/catalog
NG_APP_BACKEND_BASE_URL=http://localhost:8080/api
NG_APP_TMDB_BASE_URL=https://api.themoviedb.org/3
NG_APP_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
NG_APP_TMDB_ACCESS_TOKEN=your_tmdb_bearer_token_here
NG_APP_AUTH_DEMO_EMAIL=demo@pelisplus.com
NG_APP_AUTH_DEMO_PASSWORD=Demo1234!
NG_APP_AUTH_TOKEN_STORAGE_KEY=pelisplus_auth_token
NG_APP_MOCK_ENABLED=true

# =========================
# Production example
# =========================
# NG_APP_PRODUCTION=true
# NG_APP_NAME="Pelis Plus"
# NG_APP_INDEX_PAGE=landing
# NG_APP_POST_LOGIN_ROUTE=/landing
# NG_APP_BACKEND_BASE_URL=https://api.yourdomain.com/api
# NG_APP_TMDB_BASE_URL=https://api.themoviedb.org/3
# NG_APP_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
# NG_APP_TMDB_ACCESS_TOKEN=your_tmdb_bearer_token_here
# NG_APP_AUTH_DEMO_EMAIL=demo@pelisplus.com
# NG_APP_AUTH_DEMO_PASSWORD=Demo1234!
# NG_APP_AUTH_TOKEN_STORAGE_KEY=pelisplus_auth_token
# NG_APP_MOCK_ENABLED=false

# Server (SSR) — container always listens on 4000; this sets the host-side port
PORT=4000

# Playwright
PLAYWRIGHT_TEST_BASE_URL=http://localhost:4000

# CI flag (optional)
CI=false
