{
  "name": "angular-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "./node_modules/.bin/ng",
    "start": "node scripts/generate-env-ts.mjs && ./node_modules/.bin/ng serve",
    "build": "node scripts/generate-env-ts.mjs && ./node_modules/.bin/ng build",
    "watch": "node scripts/generate-env-ts.mjs && ./node_modules/.bin/ng build --watch --configuration development",
    "test": "node scripts/generate-env-ts.mjs && ./node_modules/.bin/ng test",
    "serve:ssr:angular-frontend": "node --env-file=.env dist/angular-frontend/server/server.mjs",
    "e2e": "node scripts/generate-env-ts.mjs && ./node_modules/.bin/ng e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,cjs,html,css,scss,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,cjs,html,css,scss,json,md,yml,yaml}\""
  },
  "private": true,
  "packageManager": "bun@1.3.10",
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.4",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jwt-decode": "^4.0.0",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "^21.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "playwright-ng-schematics": "^21.0.9",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.8"
  }
}
